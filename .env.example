# ============================================
#  ИРУ — настройки окружения (ENV)
#  Скопируйте этот файл в .env и заполните значения
# ============================================

# --- База данных PostgreSQL (обязательно) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db

# --- Публичный адрес сайта (для sitemap, canonical, OpenGraph) ---
# Замените на ваш реальный домен при развёртывании
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Порт приложения (для хостинга / Docker) ---
PORT=3000

# --- Параметры БД (используются в docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db
